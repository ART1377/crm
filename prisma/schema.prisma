// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id             String     @id @default(cuid())
  
  businessName   String
  contactPerson  String?
  phoneNumber    String
  secondaryPhone String?
  industry       String
  source         String     @default("DIRECT")
  status         String     @default("NEW")
  notes          String?
  
  activities     Activity[]
  tasks          Task[]
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  summary   String
  detail    String?
  createdAt DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title       String
  dueDate     DateTime
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model MessageTemplate {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String
  purpose   String   @default("INITIAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Messenger {
  id        String   @id @default(cuid())
  name      String   // "واتساپ", "ایتا", etc.
  key       String   @unique // "WHATSAPP", "ETA", etc.
  linkTemplate String // "https://wa.me/{phone}?text={message}"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ListOption {
  id    String @id @default(cuid())
  type  String // "SOURCE" or "INDUSTRY"
  value String
}